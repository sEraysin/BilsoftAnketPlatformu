<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bilsoft Anket</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">B</span>
                <span>Bilsoft Anket</span>
            </a>
            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Anket" asp-action="Index">Anketler</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="/Admin/Users/Index">Kullanıcı Yönetimi</a>
                }
            </nav>
        </aside>

        <div class="content-shell">
            <header class="topbar">
                <div>
                    <strong>@ViewData["Title"]</strong>
                    <span class="text-muted small d-block">Yönetim ve raporlama platformu</span>
                </div>
                <div class="topbar-user">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span>@User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Çıkış</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">Giriş</a>
                    }
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
